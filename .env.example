# Example environment file for docker-compose.
# Copy to .env and adjust as needed:  cp .env.example .env

# Port exposed on the host (default 3000)
HOST_PORT=3000

# App-level audit log (who did what via the web UI).
# Set to "false" to disable audit logging entirely.
AUDIT_LOG_ENABLED=true

# Rate limiting: max failed login attempts per IP per window
RATE_LIMIT_LOGIN_PER_WINDOW=5

# Rate limiting: window size in milliseconds (default 15 min)
RATE_LIMIT_WINDOW_MS=900000
